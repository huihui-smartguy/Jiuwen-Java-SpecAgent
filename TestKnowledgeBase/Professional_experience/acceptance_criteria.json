      "auto_evaluable": true,
      "default_status_when_missing": "not_applicable",
      "risk_scope": "ai_release",
      "evidence_map": {
        "project_profile": "AI/Agent signals detected in requirements, scenarios, code facts, or test design",
        "eval_spec": "task success criteria or eval specification exists",
        "grader_config": "grader or scoring method is declared",
        "thresholds": "pass/fail thresholds are declared"
      }
    },
