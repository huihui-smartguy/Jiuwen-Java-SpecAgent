{
  "meta": {
    "version": "1.1.0",
    "last_updated": "2026-06-29",
    "description": "AutoTestFlow 可消费的软件测试和 AI 测试专业验收标准。",
    "assertion_policy": "本文件只提供门禁和观察标准。强断言必须来自 contract.md。",
    "runtime_schema": "professional_acceptance.v1"
  },
  "criteria": [
    {
      "standard_id": "PE-SW-FAST-FEEDBACK",
      "name": "快速反馈层",
      "dimension": "software_testing",
      "source_refs": [
        "SRC-GOOGLE-TEST-PYRAMID",
        "SRC-GOOGLE-SWE-TESTING",
        "SRC-MICROSOFT-TESTING"
      ],
      "intent": "确保 PR 或小变更有快速、稳定、可定位的测试反馈。",
      "acceptance_checks": [
        "存在 PR 前可运行的 smoke/unit/contract/API 快速测试层。",
        "关键测试失败能定位到模块、接口、contract spec_id 或 fault_ref。",
        "flaky、慢测试、环境依赖失败必须在报告中单列。"
      ],
      "evidence_required": [
        "TestCases/test_design.json",
        "TestRun/case_results.json",
        "runtime_summary",
        "failure_classification"
      ],
      "release_gate": "must_for_pr",
      "applies_to": [
        "rest_api",
        "web",
        "agent",
        "dfx"
      ],
      "stage_scope": [
        "stage1_plan",
        "stage3b_case_design",
        "stage5_report"
      ],
      "auto_evaluable": true,
      "default_status_when_missing": "warn",
      "risk_scope": "pr",
      "evidence_map": {
        "TestCases/test_design.json": "test cases exist and include priority/case_kind",
        "TestRun/case_results.json": "execution summary exists",
        "failure_classification": "TestRun/results/*.json include class/status"
      }
    },
    {
      "standard_id": "PE-SW-E2E-BALANCE",
      "name": "E2E 用例比例和价值控制",
      "dimension": "software_testing",
      "source_refs": [
        "SRC-GOOGLE-TEST-PYRAMID"
      ],
      "intent": "避免测试套件退化为慢、脆弱、难定位的 E2E 堆叠。",
      "acceptance_checks": [
        "E2E 用例覆盖关键用户链路、跨模块高风险路径和真实入口。",
        "重复验证同一底层逻辑的 E2E 应降级为更小粒度测试或合并。",
        "E2E 失败必须有 trace 和定位线索。"
      ],
      "evidence_required": [
        "TestCases/test_design.json",
        "TestCases/scene_tc_mapping.json",
        "trace_files"
      ],
      "release_gate": "warn",
      "applies_to": [
        "rest_api",
        "web",
        "agent",
        "dfx"
      ],
      "stage_scope": [
        "stage3b_case_design",
        "stage5_report"
      ],
      "auto_evaluable": true,
      "default_status_when_missing": "warn",
      "risk_scope": "release",
      "evidence_map": {
        "TestCases/test_design.json": "case_kind/test_type distribution can be calculated",
        "trace_files": "TestRun/trace/*.jsonl exists for executed E2E cases"
      }
    },
    {
      "standard_id": "PE-SW-CONTRACT-COVERAGE",
      "name": "契约覆盖",
      "dimension": "software_testing",
      "source_refs": [
        "SRC-REPO-FAULTSANALYSIS",
        "SRC-MICROSOFT-TESTING"
      ],
      "intent": "保证测试断言覆盖当前 SUT 的核心契约。",
      "acceptance_checks": [
        "每条强断言用例至少包含一个 spec-required 的 oracle_ref。",
        "核心响应包装、错误格式、状态流转、id 回带、权限边界必须有覆盖或说明。",
        "contract 中未定义的行业经验点只能作为观察或人工裁决项。"
      ],
      "evidence_required": [
        "Contract/contract.md",
        "TestCases/test_design.json",
        "oracle_refs"
      ],
      "release_gate": "must_for_release",
      "applies_to": [
        "rest_api",
        "web",
        "agent",
        "dfx"
      ],
      "stage_scope": [
        "stage2_5_contract",
        "stage3b_case_design",
        "stage5_report"
      ],
      "auto_evaluable": true,
      "default_status_when_missing": "fail",
      "risk_scope": "release",
      "evidence_map": {
        "Contract/contract.md": "contract authority table exists",
        "TestCases/test_design.json": "oracle_refs cite specId values",
        "oracle_refs": "case oracle_refs contain at least one contract-backed reference"
      }
    },
    {
      "standard_id": "PE-SW-FAULT-COVERAGE",
      "name": "故障模式覆盖",
      "dimension": "software_testing",
      "source_refs": [
        "SRC-REPO-FAULTSANALYSIS",
        "SRC-NETFLIX-FIT"
      ],
      "intent": "用结构化故障知识补足需求驱动测试的失败模式盲区。",
      "acceptance_checks": [
        "高严重度 fault_ref 应有用例或明确不适用说明。",
        "历史缺陷应优先回归，至少 P1，高风险历史缺陷可提升 P0。",
        "故障断言必须经过 contract-first 调和。"
      ],
      "evidence_required": [
        "KnowledgeBase/fault_matches.json",
        "TestCases/test_design.json",
        "TestRun/case_results.json"
      ],
      "release_gate": "must_for_release",
      "applies_to": [
        "rest_api",
        "web",
        "agent",
        "dfx"
      ],
      "stage_scope": [
        "stage2_6_knowledge_match",
        "stage3b_case_design",
        "stage5_report"
      ],
      "auto_evaluable": true,
      "default_status_when_missing": "warn",
      "risk_scope": "release",
      "evidence_map": {
        "KnowledgeBase/knowledge_matches.json": "KnowledgeBase/knowledge_matches.json or KnowledgeBase/fault_matches.json exists",
        "TestCases/test_design.json": "fault_ref cases exist when knowledge matches exist",
        "TestRun/case_results.json": "fault_ref execution results are classified"
      }
    },
    {
      "standard_id": "PE-SW-OBSERVABILITY",
      "name": "可观测性验收",
      "dimension": "software_testing",
      "source_refs": [
        "SRC-MICROSOFT-TESTING",
        "SRC-MICROSOFT-AI-OBSERVABILITY"
      ],
      "intent": "确保失败可诊断，分布式调用可关联。",
      "acceptance_checks": [
        "关键请求响应有 trace/correlation id 或等价关联字段。",
        "外部依赖调用、工具调用、错误、延迟、重试和降级路径有日志或 trace。",
        "报告能关联用例、请求、响应、日志、trace 和故障分类。"
      ],
      "evidence_required": [
        "trace_files",
        "logs",
        "TestRun/case_results.json",
        "Reports/report.md"
      ],
      "release_gate": "warn",
      "applies_to": [
        "rest_api",
        "web",
        "agent",
        "dfx"
      ],
      "stage_scope": [
        "stage2_code_scan",
        "stage4_execution",
        "stage5_report"
      ],
      "auto_evaluable": true,
      "default_status_when_missing": "warn",
      "risk_scope": "release",
      "evidence_map": {
        "trace_files": "TestRun/trace/*.jsonl or result trace_file references exist",
        "logs": "log or trace evidence is linked from results",
        "TestRun/case_results.json": "results include status/class"
      }
    },
    {
      "standard_id": "PE-SW-RELIABILITY-DFX",
      "name": "可靠性与 DFX 验收",
      "dimension": "reliability",
      "source_refs": [
        "SRC-GOOGLE-SRE-RELIABILITY",
        "SRC-AWS-WA-RELIABILITY",
        "SRC-NETFLIX-FIT"
      ],
      "intent": "验证依赖失效、容量、恢复和降级能力。",
      "acceptance_checks": [
        "覆盖至少一种依赖失败场景，或说明该 SUT 无外部依赖。",
        "高风险服务应覆盖超时、重试、熔断、降级和恢复。",
        "容量、性能、MTTR 或恢复路径必须有可观测证据。"
      ],
      "evidence_required": [
        "dfx_cases",
        "fault_injection_scope",
        "metrics",
        "recovery_trace"
      ],
      "release_gate": "must_for_high_risk_release",
      "applies_to": [
        "rest_api",
        "web",
        "agent",
        "dfx"
      ],
      "stage_scope": [
        "stage3b_case_design",
        "stage4_execution",
        "stage5_report"
      ],
      "auto_evaluable": true,
      "default_status_when_missing": "requires_human_review",
      "risk_scope": "high_risk_release",
      "evidence_map": {
        "dfx_cases": "TestCases/test_design.json contains test_type=dfx or DFX knowledge matches",
        "fault_injection_scope": "DFX fault refs or explicit scope note exists",
        "metrics": "metrics or recovery evidence exists"
      }
    },
    {
      "standard_id": "PE-SW-CANARY-READINESS",
      "name": "Canary 和渐进发布就绪",
      "dimension": "release_engineering",
      "source_refs": [
        "SRC-GOOGLE-SRE-RELIABILITY",
        "SRC-NETFLIX-KAYENTA"
      ],
      "intent": "高风险发布必须能通过指标比较和回滚机制限制影响面。",
      "acceptance_checks": [
        "定义 baseline/canary 或等价灰度对照。",
        "关键指标包含错误率、延迟、资源、异常、业务成功率。",
        "无数据、指标缺失或显著退化必须阻断或人工确认。"
      ],
      "evidence_required": [
        "metric_config",
        "baseline_metrics",
        "canary_metrics",
        "rollback_plan"
      ],
      "release_gate": "must_for_production_rollout",
      "applies_to": [
        "rest_api",
        "web",
        "agent",
        "dfx"
      ],
      "stage_scope": [
        "stage5_report"
      ],
      "auto_evaluable": false,
      "default_status_when_missing": "requires_human_review",
      "risk_scope": "production_rollout",
      "evidence_map": {
        "metric_config": "release metric configuration exists",
        "baseline_metrics": "baseline/canary comparison evidence exists",
        "rollback_plan": "rollback or mitigation plan exists"
      }
    },
    {
      "standard_id": "PE-AI-SUCCESS-CRITERIA",
      "name": "AI 成功标准定义",
      "dimension": "ai_testing",
      "source_refs": [
